[Unit]
Description=Checklist FastAPI Backend
After=network.target

[Service]
User=www-data
Group=www-data
WorkingDirectory=/opt/checklist/check-list__app
Environment="PATH=/opt/checklist/check-list__app/venv/bin"
Environment="PYTHONUNBUFFERED=1"
EnvironmentFile=/opt/checklist/check-list__app/.env
ExecStart=/opt/checklist/check-list__app/venv/bin/python -m uvicorn app.main:app --host 127.0.0.1 --port 8000
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
